# Copy to .env at repo root and adjust.

NODE_ENV=development
PORT=4700

# Optional: public URL of the service (no trailing slash) — for absolute links behind a proxy.
# PUBLIC_ORIGIN=https://polka.example.com

# Hard caps for WxH placeholder dimensions (validated in API / generator).
PLACEHOLDER_MAX_WIDTH=4000
PLACEHOLDER_MAX_HEIGHT=4000

# Freepik provider key for /stock API.
FREEPIK_API_KEY=

# Stock image API limits and cache settings.
STOCK_MAX_WIDTH=4096
STOCK_MAX_HEIGHT=4096
STOCK_CACHE_DIR=.cache/polka-stock
STOCK_CACHE_TTL_SEC=2592000
STOCK_PROVIDER_TIMEOUT_MS=3000
STOCK_DEFAULT_FORMAT=webp
STOCK_DEFAULT_QUALITY=82
STOCK_FALLBACK_TEXT=no image
